# ── Server ───────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ─────────────────────────────────────────────────
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your_mysql_password_here
DB_NAME=hotel_db

# ── JWT ──────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_at_least_64_characters
JWT_EXPIRES_IN=7d

# ── CORS — Frontend URLs ─────────────────────────────────────
# In development these are automatically allowed: localhost:3000 and localhost:3001
# Only needed if you deploy to a different domain:
CLIENT_URL=http://localhost:3000
ADMIN_URL=http://localhost:3001

# ── Admin Registration Key ───────────────────────────────────
# Used to protect the admin signup page at localhost:3001/register
# Change this to a strong secret before going live!
SETUP_KEY=HOTEL_ADMIN_2024

# ── Email (optional) — for contact form notifications ────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password
HOTEL_EMAIL=info@araliyaresort.lk
